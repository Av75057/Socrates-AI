# Скопируй в .env только если нужно. Для `npm run dev` обычно НИЧЕГО не задавай —
# тогда запросы идут на /api и Vite проксирует их на http://127.0.0.1:8000 (см. vite.config.js).

# НЕ используй 127.0.0.1, если открываешь UI с телефона/другого ПК по IP в сети —
# браузер на том устройстве будет стучаться в свой localhost, а не в ПК с бэкендом.
# VITE_API_URL=http://192.168.x.x:8000

# Статическая сборка без прокси (nginx только отдаёт файлы) — укажи URL API:
# VITE_API_URL=https://твой-домен.example/api
