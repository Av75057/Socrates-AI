# Пример для Ubuntu: скопируй в /etc/nginx/sites-available/socrates
# и подставь свой домен + пути к проекту.
#
# sudo ln -s /etc/nginx/sites-available/socrates /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
#
# SSL: сначала подними только HTTP (блок server на :80), проверь сайт,
# затем: sudo certbot --nginx -d ТВОЙ_ДОМЕН

upstream socrates_api {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name ПОДСТАВЬ_ДОМЕН.example;

    # После certbot сюда добавятся редирект на HTTPS или отдельный файл
    root /var/www/socrates/dist;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 256;

    # API FastAPI: /api/* → http://127.0.0.1:8000/*
    location /api/ {
        proxy_pass http://socrates_api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # React Router: SPA
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Кэш статики Vite (имена файлов с хэшем)
    location /assets/ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
}
