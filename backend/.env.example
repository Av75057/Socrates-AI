# OpenRouter (обязательно для ответов LLM)
OPENROUTER_API_KEY=

# Продакшен по публичному IP (если фронт и API с разных origin’ов):
# CORS_ORIGINS=http://128.0.133.250,http://128.0.133.250:5173

# БД и JWT (пользователи / админка)
# DATABASE_URL=sqlite:///./socrates.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/socrates
# JWT_SECRET=change-me-long-random
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Опционально
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=memory
# OPENROUTER_HTTP_REFERER=http://localhost:5173
# OPENROUTER_X_TITLE=Socrates AI
#
# Дешёвая модель для анализа логики и глубины ответа (педагогика):
# OPENROUTER_MODEL_PEDAGOGY=google/gemini-2.0-flash-001
