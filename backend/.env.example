# Глобальный LLM: openrouter (облако) или ollama (локально)
# LLM_PROVIDER=openrouter
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b-instruct

# OpenRouter (для облака и как fallback при сбое Ollama)
OPENROUTER_API_KEY=

# Продакшен по публичному IP (если фронт и API с разных origin’ов):
# CORS_ORIGINS=http://128.0.133.250,http://128.0.133.250:5173
# Dev с LAN: дополнительные origin’ы при необходимости; для IP в подсети также сработает allow_origin_regex в main.py.
#
# Публичные ссылки на диалоги: базовый URL фронта для share_url и OG (в проде https://ваш-домен)
# PUBLIC_SITE_URL=https://app.example.com

# БД и JWT (пользователи / админка)
# DATABASE_URL=sqlite:///./socrates.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/socrates
# JWT_SECRET=change-me-long-random
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Опционально
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=memory
# OPENROUTER_HTTP_REFERER=http://localhost:5173
# OPENROUTER_X_TITLE=Socrates AI
#
# Дешёвая модель для анализа логики и глубины ответа (педагогика):
# OPENROUTER_MODEL_PEDAGOGY=google/gemini-2.0-flash-001
#
# Долговременные навыки и педагогика (БД):
# SKILL_UPDATE_ENABLED=true
# LOGICAL_CONSISTENCY_MODEL=google/gemini-2.0-flash-lite
# LOGICAL_CONSISTENCY_EVERY_N=5
# CONVERSATION_OPENING_ENABLED=true
#
# Email-отчёты учителя:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=teacher@example.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=teacher@example.com
# SMTP_USE_TLS=true
